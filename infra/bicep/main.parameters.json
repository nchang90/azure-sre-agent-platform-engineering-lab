{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "uksouth"
    },
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "agentName": {
      "value": "${AGENT_NAME=sre-agent}"
    },
    "accessLevel": {
      "value": "${AGENT_ACCESS_LEVEL=Low}"
    },
    "actionMode": {
      "value": "${AGENT_ACTION_MODE=Review}"
    }
  }
}
